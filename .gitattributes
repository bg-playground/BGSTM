# Auto detect text files and perform LF normalization
* text=auto

# Force LF line endings for shell scripts (critical for Docker on Windows)
*.sh text eol=lf

# Force LF for other files used in Linux containers
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf
*.sql text eol=lf
*.ini text eol=lf
*.cfg text eol=lf
*.toml text eol=lf
Makefile text eol=lf

# Binary files - do not modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
